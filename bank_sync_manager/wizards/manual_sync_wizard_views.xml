<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_manual_sync_wizard_form" model="ir.ui.view">
        <field name="name">manual.sync.wizard.form</field>
        <field name="model">manual.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Manual Sync">
                <group>
                    <group>
                        <field name="connection_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="auto_match"/>
                        <field name="match_partner_only" invisible="not auto_match"/>
                    </group>
                </group>
                <footer>
                    <button name="action_sync" type="object" string="Sync Now" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_manual_sync_wizard" model="ir.actions.act_window">
        <field name="name">Manual Sync</field>
        <field name="res_model">manual.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

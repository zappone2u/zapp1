<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_event_form_inherit_custom" model="ir.ui.view">
        <field name="name">event.event.form.inherit.nbseances</field>
        <field name="model">event.event</field>
        <field name="inherit_id" ref="event.view_event_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group/group[1]" position="inside">
                <field name="nb_seances"/>
                <field name="paye_sur_place"/>
                <field name="date_limite_confirmation"/>
                <field name="seats_available" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

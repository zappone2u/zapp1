<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ons_event_event_ticket_view_tree_from_event" model="ir.ui.view">
        <field name="name">ons.event.event.ticket.view.tree</field>
        <field name="model">event.event.ticket</field>
        <field name="inherit_id" ref="event.event_event_ticket_view_tree_from_event" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="ons_price_for_member"/>
            </xpath>
        </field>
    </record>
</odoo>

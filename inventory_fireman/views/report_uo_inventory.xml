<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         Rapport PDF : Inventaire UO — accessible dès le palier Caserne
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Action de rapport -->
    <record id="action_report_uo_inventory" model="ir.actions.report">
        <field name="name">Rapport Inventaire UO</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">inventory_fireman.report_uo_inventory_document</field>
        <field name="report_file">inventory_fireman.report_uo_inventory_document</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template du document PDF -->
    <template id="report_uo_inventory_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- En-tête rapport -->
                    <div style="background:linear-gradient(135deg,#e74c3c 0%,#c0392b 100%);color:white;padding:25px 30px;margin:-20px -20px 30px -20px;border-radius:4px 4px 0 0;">
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <div>
                                <h2 style="margin:0;font-size:22px;font-weight:700;">
                                    <span style="font-size:28px;">🚒</span>
                                    Rapport d'inventaire
                                </h2>
                                <p style="margin:5px 0 0 0;opacity:0.85;font-size:13px;">
                                    Inventaire Pompiers — Document généré automatiquement
                                </p>
                            </div>
                            <div style="text-align:right;font-size:12px;opacity:0.85;">
                                <div>
                                    Généré le :
                                    <t t-out="context.get('generated_at') or ''"/>
                                </div>
                                <div>
                                    Par :
                                    <t t-out="context.get('generated_by') or ''"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Informations UO -->
                    <t t-set="uo" t-value="doc"/>
                    <t t-set="data_ctx" t-value="context"/>

                    <table style="width:100%;border-collapse:collapse;margin-bottom:20px;">
                        <tr>
                            <td style="width:50%;vertical-align:top;padding-right:15px;">
                                <div style="border:1px solid #ddd;border-radius:6px;padding:15px;">
                                    <h4 style="color:#e74c3c;margin:0 0 12px 0;font-size:14px;text-transform:uppercase;letter-spacing:0.5px;">
                                        🏢 Unité Opérationnelle
                                    </h4>
                                    <table style="width:100%;font-size:12px;">
                                        <tr>
                                            <td style="color:#666;padding:3px 0;width:40%;">Nom :</td>
                                            <td style="font-weight:600;"><t t-out="uo.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Code UO :</td>
                                            <td><t t-out="uo.uo_code or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Plan :</td>
                                            <td>
                                                <t t-if="uo.subscription_tier == 'caserne'">Caserne</t>
                                                <t t-elif="uo.subscription_tier == 'flotte'">Flotte</t>
                                                <t t-else=""><t t-out="uo.subscription_tier or '—'"/></t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Email :</td>
                                            <td><t t-out="uo.email or '—'"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                            <td style="width:50%;vertical-align:top;">
                                <div style="border:1px solid #ddd;border-radius:6px;padding:15px;">
                                    <h4 style="color:#e74c3c;margin:0 0 12px 0;font-size:14px;text-transform:uppercase;letter-spacing:0.5px;">
                                        📊 Synthèse
                                    </h4>
                                    <table style="width:100%;font-size:12px;">
                                        <tr>
                                            <td style="color:#666;padding:3px 0;width:60%;">Total inventaires :</td>
                                            <td style="font-weight:700;font-size:14px;">
                                                <t t-out="data_ctx.get('total_inventories', 0)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Complets :</td>
                                            <td style="color:#27ae60;font-weight:600;">
                                                <t t-out="data_ctx.get('complete_count', 0)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Incomplets :</td>
                                            <td style="color:#e67e22;font-weight:600;">
                                                <t t-out="data_ctx.get('incomplete_count', 0)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Véhicules :</td>
                                            <td style="font-weight:600;">
                                                <t t-out="uo.vehicle_count"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="color:#666;padding:3px 0;">Pompiers actifs :</td>
                                            <td style="font-weight:600;">
                                                <t t-out="uo.pompier_count"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- Statistiques par véhicule -->
                    <t t-set="vehicle_stats" t-value="data_ctx.get('vehicle_stats', [])"/>
                    <t t-if="vehicle_stats">
                        <h3 style="color:#2c3e50;font-size:15px;border-bottom:2px solid #e74c3c;padding-bottom:6px;margin-bottom:12px;">
                            🚒 Inventaires par véhicule
                        </h3>
                        <table style="width:100%;border-collapse:collapse;font-size:11px;margin-bottom:20px;">
                            <thead>
                                <tr style="background:#e74c3c;color:white;">
                                    <th style="padding:8px 10px;text-align:left;">Véhicule</th>
                                    <th style="padding:8px 10px;text-align:center;">Total</th>
                                    <th style="padding:8px 10px;text-align:center;">Complets</th>
                                    <th style="padding:8px 10px;text-align:center;">Taux</th>
                                    <th style="padding:8px 10px;text-align:left;">Dernier inventaire</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="vehicle_stats" t-as="vs">
                                    <tr t-attf-style="background:#{(vs_index % 2 == 0) and '#f9f9f9' or '#ffffff'}">
                                        <td style="padding:7px 10px;font-weight:500;">
                                            <t t-out="vs['vehicle'].label or vs['vehicle'].name"/>
                                        </td>
                                        <td style="padding:7px 10px;text-align:center;">
                                            <t t-out="vs['total']"/>
                                        </td>
                                        <td style="padding:7px 10px;text-align:center;color:#27ae60;font-weight:600;">
                                            <t t-out="vs['complete']"/>
                                        </td>
                                        <td style="padding:7px 10px;text-align:center;">
                                            <t t-if="vs['total'] > 0">
                                                <t t-out="round(vs['complete'] * 100 / vs['total'])"/>%
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td style="padding:7px 10px;color:#666;font-size:10px;">
                                            <t t-if="vs['last_date']">
                                                <t t-out="vs['last_date'].strftime('%d/%m/%Y')"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Manques signalés -->
                    <t t-set="lacks" t-value="data_ctx.get('lacks', [])"/>
                    <t t-if="lacks">
                        <h3 style="color:#2c3e50;font-size:15px;border-bottom:2px solid #e67e22;padding-bottom:6px;margin-bottom:12px;">
                            ⚠️ Manques signalés
                        </h3>
                        <table style="width:100%;border-collapse:collapse;font-size:11px;margin-bottom:20px;">
                            <thead>
                                <tr style="background:#e67e22;color:white;">
                                    <th style="padding:8px 10px;text-align:left;">Date</th>
                                    <th style="padding:8px 10px;text-align:left;">Véhicule</th>
                                    <th style="padding:8px 10px;text-align:left;">Inventoriste</th>
                                    <th style="padding:8px 10px;text-align:left;">Manques</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lacks" t-as="lack">
                                    <tr t-attf-style="background:#{(lack_index % 2 == 0) and '#fffaf5' or '#ffffff'}">
                                        <td style="padding:6px 10px;color:#666;font-size:10px;">
                                            <t t-if="lack['date']">
                                                <t t-out="lack['date'].strftime('%d/%m/%Y')"/>
                                            </t>
                                        </td>
                                        <td style="padding:6px 10px;font-weight:500;">
                                            <t t-out="lack['vehicle'] or '—'"/>
                                        </td>
                                        <td style="padding:6px 10px;">
                                            <t t-out="lack['inventor'] or '—'"/>
                                        </td>
                                        <td style="padding:6px 10px;color:#c0392b;">
                                            <t t-out="lack['lack']"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Historique inventaires -->
                    <t t-set="inventories" t-value="data_ctx.get('inventories')"/>
                    <t t-if="inventories">
                        <h3 style="color:#2c3e50;font-size:15px;border-bottom:2px solid #3498db;padding-bottom:6px;margin-bottom:12px;">
                            📋 Historique des inventaires
                        </h3>
                        <table style="width:100%;border-collapse:collapse;font-size:10px;margin-bottom:20px;">
                            <thead>
                                <tr style="background:#3498db;color:white;">
                                    <th style="padding:7px 8px;text-align:left;">Date</th>
                                    <th style="padding:7px 8px;text-align:left;">Véhicule</th>
                                    <th style="padding:7px 8px;text-align:left;">Inventoriste</th>
                                    <th style="padding:7px 8px;text-align:center;">Grade</th>
                                    <th style="padding:7px 8px;text-align:center;">Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="inventories" t-as="inv">
                                    <tr t-attf-style="background:#{(inv_index % 2 == 0) and '#f5f9ff' or '#ffffff'}">
                                        <td style="padding:5px 8px;color:#555;">
                                            <t t-if="inv.date">
                                                <t t-out="inv.date.strftime('%d/%m/%Y %H:%M')"/>
                                            </t>
                                            <t t-else="">
                                                <t t-out="inv.inventory_date_str or '—'"/>
                                            </t>
                                        </td>
                                        <td style="padding:5px 8px;font-weight:500;">
                                            <t t-out="inv.vehicle or '—'"/>
                                        </td>
                                        <td style="padding:5px 8px;">
                                            <t t-out="inv.inventor_name or '—'"/>
                                        </td>
                                        <td style="padding:5px 8px;text-align:center;color:#666;">
                                            <t t-out="inv.rank or '—'"/>
                                        </td>
                                        <td style="padding:5px 8px;text-align:center;">
                                            <t t-if="inv.inventor_full">
                                                <span style="background:#27ae60;color:white;padding:2px 7px;border-radius:10px;font-size:9px;">Complet</span>
                                            </t>
                                            <t t-else="">
                                                <span style="background:#f39c12;color:white;padding:2px 7px;border-radius:10px;font-size:9px;">Incomplet</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Pied de page -->
                    <div style="border-top:1px solid #ddd;padding-top:12px;margin-top:20px;color:#aaa;font-size:9px;text-align:center;">
                        Rapport généré par Inventaire Pompiers (ZappOne) — Document confidentiel — Usage interne uniquement
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>

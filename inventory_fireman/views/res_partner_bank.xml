<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="ons_view_partner_bank_form">
        <field name="name">ONS Res Partner Bank Form</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="account.view_partner_bank_form_inherit_account" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="ons_logo" widget="image" class="oe_avatar"/>
                <field name="ons_company_details"/>
            </xpath>
        </field>
    </record>
</odoo>

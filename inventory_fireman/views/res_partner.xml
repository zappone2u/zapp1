<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_partner_form">
        <field name="name">ONS Res Partner Form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="ons_spouse" invisible="is_company"/>
                <field name="ons_beneficiary" invisible="is_company"/>
                <field name="ons_commitment_date" invisible="is_company"/>
            </xpath>
            <xpath expr="//field[@name='phone']/.." position="after">
                <field name="ons_private_phone" invisible="is_company" widget="phone"/>
            </xpath>
        </field>
    </record>
</odoo>

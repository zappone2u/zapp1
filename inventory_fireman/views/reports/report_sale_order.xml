<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="ons_report_saleorder_document" inherit_id="sale.report_saleorder_document">
            <xpath expr="//t[@t-set='forced_vat']" position="after">
                <t t-set="is_guides_order" t-value="doc.is_guides_order"/>
            </xpath>
            <xpath expr="//t[@t-set='forced_vat']" position="replace"/>

            <xpath expr="//span[@t-field='doc.note']" position="replace">
                <t t-if="not is_guides_order">
                    <span t-field="doc.note"
                        t-attf-style="#{'text-align:justify;text-justify:inter-word;' if doc.company_id.terms_type != 'html' else ''}"
                        name="order_note" />
                </t>
            </xpath>
            <xpath expr="//span[@t-field='doc.payment_term_id.note']/.." position="replace"/>
        </template>
    </data>
</odoo>
